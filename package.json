{
  "name": "boing-wallet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "node scripts/generate-extension-icons.js && vite build --config vite.extension.config.ts",
    "preview": "vite preview",
    "pages:deploy": "pnpm build && wrangler pages deploy dist --project-name=boing-wallet",
    "pages:dev": "vite"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "wrangler": "^3.91.0"
  }
}
