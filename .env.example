# Boing RPC endpoints (set in Cloudflare Pages build env or .env)
VITE_BOING_TESTNET_RPC=https://testnet-rpc.boing.network
# Optional until official mainnet RPC is published (boing.network docs/THREE-CODEBASE-ALIGNMENT.md).
# VITE_BOING_MAINNET_RPC=

# -----------------------------------------------------------------------------
# Public JSON-RPC (boing-node) — native DEX L1 discovery
#
# These variables apply to the **Boing node** process that serves JSON-RPC, not to this
# repository’s Vite/Worker build. Downstream gateways and clients may rely on stable L1
# method names from `boing_getNetworkInfo` (`developer.dex_discovery_methods`) and
# `boing_getRpcMethodCatalog`; operators should run a current `boing-node` and restart
# it after changing environment variables.
#
# Normative spec: https://github.com/Boing-Network/boing.network/blob/main/docs/RPC-API-SPEC.md
# (§ DEX discovery). Example block below is aligned with
# `tools/boing-node-public-testnet.env.example` on boing.network (2026-05-21 live stack).
#
# BOING_CANONICAL_NATIVE_DEX_FACTORY — pair-directory AccountId (64 hex, optional 0x).
# The three BOING_DEX_* knobs tune on-node discovery; match or override defaults as needed.
# -----------------------------------------------------------------------------

BOING_CANONICAL_NATIVE_DEX_FACTORY=0x58112627fc84618a27b82e9af82bc9a51761c6d3cca1260c93d56d22b6c481a1
# Recent blocks scanned for ContractDeployWithPurposeAndMetadata symbol/name (max 500000).
BOING_DEX_TOKEN_METADATA_SCAN_BLOCKS=8192
# Cap receipt rows examined per discovery RPC for factory Log3 registers; 0 = unlimited.
BOING_DEX_DISCOVERY_MAX_RECEIPT_SCANS=500000
# JSON map of "0x" + 64-hex token id -> decimals 0–255; {} uses default 18 per token.
BOING_DEX_TOKEN_DECIMALS_JSON={}
