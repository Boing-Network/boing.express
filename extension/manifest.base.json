{
  "manifest_version": 3,
  "name": "Boing Express",
  "version": "0.1.2",
  "description": "The non-custodial wallet for Boing Network. Your keys, your BOING - use the DeFi that always bounces back, right from your browser.",
  "author": "Boing Express",
  "homepage_url": "https://boing.express",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Boing Express"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "wallet@boing.express",
      "strict_min_version": "109.0"
    }
  }
}
