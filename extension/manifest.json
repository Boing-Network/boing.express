{
  "manifest_version": 3,
  "name": "Boing Express",
  "version": "0.1.0",
  "description": "The non-custodial wallet for Boing Network. Your keys, your BOING — use the DeFi that always bounces back, right from your browser.",
  "author": "Boing Express",
  "homepage_url": "https://boing.express",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Boing Express"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://testnet-rpc.boing.network/*",
    "https://rpc.boing.network/*",
    "https://boing.network/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wallet@boing.express",
      "strict_min_version": "109.0"
    }
  }
}
